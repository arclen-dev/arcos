configuration {
    modi:               "drun,run,window";
    show-icons:         true;
    icon-theme:         "Papirus";
    drun-display-format: "{name}";
    display-drun:       "  Apps";
    display-run:        "  Run";
    display-window:     "  Windows";
    font:               "Inter 12";
    hover-select:       true;
    me-select-entry:    "";
    me-accept-entry:    "MousePrimary";
}

@import "wallust/colors-rofi.rasi"
@theme "launcher"
